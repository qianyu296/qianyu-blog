# Copy to application-local.properties for local-only settings.
spring.datasource.url=jdbc:mysql://localhost:3306/qianyu_blog?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
spring.datasource.username=root
spring.datasource.password=change-me-db-password
qianyu.jwt.secret=change-me-qianyu-blog-jwt-secret-at-least-32-chars
qianyu.admin.username=change-me-admin-username
qianyu.admin.password=change-me-admin-password
qianyu.storage.music-dir=uploads/music
qianyu.storage.media-dir=uploads/media
